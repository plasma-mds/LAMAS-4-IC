{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Anion_IC_Schema",
  "type": "object",
  "properties": {
    "dataCite": {
      "title": "Data citation information",
      "description": "Mandatory information for accurate and consistent identification of a resource for citation and retrieval purposes. According to DataCite V 4.6",
      "properties": {
        "identifierObject": {
          "type": "object",
          "title": "Identifier",
          "description": "",
          "properties": {
            "identifier": {
              "type": "string",
              "title": "Identifier",
              "description": "The Identifier is a unique string that identifies a resource."
            },
            "identifierType": {
              "type": "string",
              "title": "identifierType",
              "description": "The type of Identifier.",
              "enum": [
                "DOI"
              ]
            }
          }
        },
        "creator": {
          "title": "Creator",
          "description": "The main researchers involved in producing the data, or the authors of the publication, in priority order. To supply multiple creators, repeat this property.",
          "items": {
            "type": "object",
            "properties": {
              "creatorName": {
                "title": "Creator full name",
                "description": "The full name of the creator.",
                "type": "string"
              },
              "nameType": {
                "type": "string",
                "title": "Name type",
                "description": "The type of name.",
                "enum": [
                  "Organizational",
                  "Personal"
                ]
              },
              "givenName": {
                "title": "Given name",
                "description": "The personal or first name of the creator",
                "type": "string"
              },
              "familyName": {
                "title": "Family name",
                "description": "The surname or last name of the creator",
                "type": "string"
              }
            }
          },
          "type": "array"
        },
        "title": {
          "title": "Title",
          "description": "",
          "items": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "object",
            "properties": {
              "title": {
                "type": "string",
                "title": "Title",
                "description": "A name or title by which a resource is known. May be the title of a dataset or the name of a piece of software or an instrument."
              },
              "titleType": {
                "type": "string",
                "title": "Title type",
                "description": "The type of Title (other than the Main Title).",
                "enum": [
                  "",
                  "AlternativeTitle",
                  "Subtitle",
                  "TranslatedTitle",
                  "Other"
                ]
              }
            }
          },
          "type": "array"
        },
        "publisher": {
          "title": "Publisher",
          "description": "",
          "type": "object",
          "properties": {
            "publisher": {
              "type": "string",
              "title": "Publisher",
              "description": "The name of the entity that holds, archives, publishes, prints, distributes, releases, issues, or produces the resource. This property will be used to formulate the citation, so consider the prominence of the role."
            },
            "publisherIdentifier": {
              "type": "string",
              "title": "Publisher identifier",
              "description": "Uniquely identifies the publisher, according to various schemes."
            },
            "publisherIdentifierScheme": {
              "type": "string",
              "title": "Publisher identifier scheme",
              "description": "The name of the publisher identifier scheme.",
              "enum": [
                "ROR",
                "re3data",
                "VIAF",
                "Wikidata",
                "Crossref Funder ID",
                "ISNI",
                "OpenDOAR",
                "FAIRsharing",
                "ISSN"
              ]
            },
            "schemeURI": {
              "type": "string",
              "title": "Scheme URI",
              "description": "The URI of the publisher identifier scheme."
            }
          }
        },
        "publicationYear": {
          "title": "Publication year",
          "description": "The year when the data was or will be made publicly available. In the case of resources such as software or dynamic data where there may be multiple releases in one year, include the Date property and sub-properties (dateType/dateInformation) to provide more information about the publication or release date details.",
          "type": "number",
          "minimum": 0
        },
        "resourceType": {
          "title": "Resource type",
          "description": "",
          "type": "object",
          "properties": {
            "resourceType": {
              "type": "string",
              "title": "Resource type",
              "description": "A description of the resource."
            },
            "resourceTypeGeneral": {
              "title": "Resource type general",
              "description": "The general type of a resource.",
              "type": "string",
              "enum": [
                "Dataset",
                "Report",
                "Standard"
              ]
            }
          }
        }
      },
      "type": "object"
    },
    "identificationInformation": {
      "title": "Identification information",
      "description": "",
      "required": [
        "measurementDate",
        "projectName",
        "deviceBrand",
        "sequenceName",
        "deviceID"
      ],
      "properties": {
        "sequenceName": {
          "title": "Sequence name",
          "description": "Name of the measured sequence.",
          "type": "string",
          "$id": "http://purl.obolibrary.org/obo/MS_4000089"
        },
        "measurementDate": {
          "title": "Date of measurement begin",
          "description": "dd.mm.yyyy",
          "$id": "http://purl.obolibrary.org/obo/AGRO_00010151",
          "type": "string"
        },
        "projectName": {
          "title": "Project name",
          "description": "",
          "$id": "http://purl.obolibrary.org/obo/NCIT_C165056",
          "type": "string"
        },
        "deviceBrand": {
          "title": "Device brand",
          "description": "ID of the used Device",
          "type": "string",
          "enum": [
            "ThermoFisher Scientific",
            "Shimadzu",
            "Agilent",
            "Metrohm",
            "membraPure",
            "OSRAM"
          ]
        },
        "deviceID": {
          "title": "Device ID",
          "description": "Which device was used",
          "type": "string",
          "$id": "https://plasma-mds.org/ontology/plasma-o/PLSMO_C0003"
        }
      },
      "type": "object"
    },
    "instrumentMethod": {
      "title": "Instrument method",
      "description": "Method that defines the device parameter.",
      "required": [
        "runtime",
        "injectionVolume",
        "pumpSettings",
        "eluentGeneratorSettings",
        "samplerSettings",
        "methodName"
      ],
      "properties": {
        "methodName": {
          "title": "Instrument method name",
          "description": "",
          "type": "string",
          "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_A0001"
        },
        "runtime": {
          "title": "Runtime [min]",
          "description": "Defines the length of each measurement. Ranges from 3 to 100000 minutes.",
          "type": "number",
          "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0077",
          "minimum": 3,
          "maximum": 100000
        },
        "injectionVolume": {
          "title": "Injection volume [\\mu l]",
          "description": "Amount of sample that will be injected per measurment. Ranges from 5 to 10 µl.",
          "$id": "http://purl.allotrope.org/ontologies/result#AFR_0001267",
          "type": "number",
          "minimum": 5,
          "maximum": 10
        },
        "pumpSettings": {
          "title": "Pump settings",
          "description": "",
          "required": [
            "pumpMode",
            "eluentFlowRate",
            "lowerPressureLimit",
            "upperPressureLimit",
            "eluentChannels"
          ],
          "properties": {
            "pumpMode": {
              "title": "Pump mode",
              "description": "isocratic: eluent generated from one solvent,\n\ngradient: eluent generated from a mixture of up to 4 solvents",
              "type": "string",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0009",
              "enum": [
                "isocratic",
                "gradient"
              ]
            },
            "eluentFlowRate": {
              "title": "Eluent flow rate [ml/min]",
              "description": "",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0079",
              "type": "number",
              "minimum": 0,
              "maximum": 3
            },
            "lowerPressureLimit": {
              "title": "Lower pressure limit [psi]",
              "description": "Lower boundary for the system pressure, ranges from 200 to 4999 psi.",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0080",
              "type": "number",
              "minimum": 200,
              "maximum": 4999
            },
            "upperPressureLimit": {
              "title": "Upper pressure limit [psi]",
              "description": "Upper boundary for the system pressure, ranges from 201 to 5000 psi. Must be higher than the lower pressure limit!",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0082",
              "minimum": 201,
              "maximum": 5000
            },
            "pumpGradientPlan": {
              "title": "Pump gradient plan",
              "description": "",
              "properties": {
                "pumpGradientTable": {
                  "title": "Pump gradient table",
                  "description": "starttime1 endtime1 flowrate1 %eluentchannelB1 %eluentchannelC1 %eluentchannelD1, starttime2 endtime2 flowrate2 %eluentchannelB2 %eluentchannelC2 %eluentchannelD2 ... ",
                  "type": "string",
                  "contentEncoding": "base64"
                }
              },
              "type": "object"
            },
            "eluentChannels": {
              "title": "Eluent channels",
              "description": "If pump mode isocratic: A = 100%, B,C,D = 0%. If pump mode gradient: A+B+C+D = 100% in total.",
              "required": [
                "channelD",
                "channelC",
                "channelB",
                "channelA"
              ],
              "properties": {
                "channelA": {
                  "title": "Channel A [%]",
                  "description": "",
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "channelB": {
                  "title": "Channel B [%]",
                  "description": "",
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "channelC": {
                  "title": "Channel C [%]",
                  "description": "",
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "channelD": {
                  "title": "Channel D [%]",
                  "description": "",
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                }
              },
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0057",
              "type": "object"
            }
          },
          "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0007",
          "type": "object"
        },
        "eluentGeneratorSettings": {
          "title": "Eluent generator settings",
          "description": "",
          "required": [
            "eluentCartridge",
            "eluentMode",
            "eluentConcentration"
          ],
          "properties": {
            "eluentCartridge": {
              "title": "Eluent cartridge",
              "description": "",
              "type": "string",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0005",
              "enum": [
                "KOH 500",
                "None"
              ]
            },
            "eluentMode": {
              "title": "Eluent mode",
              "description": "isocratic: one fix concentration for whole measurement,\ngradient: concentration shifts over defined time frame(s)",
              "type": "string",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0006",
              "enum": [
                "isocratic",
                "gradient"
              ]
            },
            "eluentConcentration": {
              "title": "Eluent concentration [mM]",
              "description": "",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0058",
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "concentrationGradientPlan": {
              "title": "Concentration gradient plan",
              "description": "",
              "properties": {
                "concentrationGradientTable": {
                  "title": "Concentration gradient table",
                  "description": "Format:\nstarttime1 endtime1 concentration1;\nstarttime2 endtime2 concentration2; ",
                  "type": "string",
                  "contentEncoding": "base64"
                }
              },
              "type": "object"
            }
          },
          "type": "object",
          "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0004"
        },
        "samplerSettings": {
          "title": "Sampler settings",
          "description": "",
          "required": [
            "samplerTemperature",
            "temperatureDeviation"
          ],
          "properties": {
            "samplerTemperature": {
              "title": "Sampler temperature [°C]",
              "description": "Temperature for sample storage in the sampler.",
              "$id": "http://purl.allotrope.org/ontologies/result#AFR_0001538",
              "type": "number",
              "minimum": 4,
              "maximum": 60
            },
            "temperatureDeviation": {
              "title": "Temperature deviation [°C]",
              "description": "Accepted deviation from set sampler temperature.",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0083",
              "minimum": 0,
              "maximum": 10
            }
          },
          "type": "object",
          "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0002"
        },
        "uvVisDetector": {
          "title": "UV/VIS detector",
          "description": "",
          "properties": {
            "wavelength1": {
              "title": "Wavelength channel 1 [nm]",
              "description": "Ranges from 190 to 900 nm.",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0075",
              "type": "number",
              "minimum": 190,
              "maximum": 900
            },
            "wavelength2": {
              "title": "Wavelength channel 2 [nm]",
              "description": "Ranges from 190 to 900 nm.",
              "type": "number",
              "minimum": 190,
              "maximum": 900
            },
            "wavelength3": {
              "title": "Wavelength channel 3 [nm]",
              "description": "Ranges from 190 to 900 nm.",
              "type": "number",
              "minimum": 190,
              "maximum": 900
            },
            "wavelength4": {
              "title": "Wavelength channel 4 [nm]",
              "description": "Ranges from 190 to 900 nm.",
              "type": "number",
              "minimum": 190,
              "maximum": 900
            },
            "uvVisDataCollectionRate": {
              "title": "UV/VIS data collection rate [Hz]",
              "description": "Ranges from 0.2 t o100 Hz.",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0074",
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "timeConstant": {
              "title": "Time constant [s]",
              "description": "Ranges from 0 to 4.55s.",
              "type": "number",
              "$id": "http://www.ontology-of-units-of-measure.org/resource/om-2/TimeConstant",
              "minimum": 0,
              "maximum": 5
            }
          },
          "$id": "http://purl.obolibrary.org/obo/OBI_0000505",
          "type": "object"
        },
        "cdDetectorSettings": {
          "title": "Conductivity detector settings",
          "description": "",
          "properties": {
            "cd1Channel": {
              "title": "CD1 channel",
              "description": "",
              "type": "boolean",
              "default": false
            },
            "cd1TotalChannel": {
              "title": "CD1 total channel",
              "description": "",
              "type": "boolean",
              "default": true
            },
            "cdDataCollectionRate": {
              "title": "CD data collection rate [Hz]",
              "description": "",
              "type": "string",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0052",
              "enum": [
                "1.0 Hz",
                "2.0 Hz",
                "5.0 Hz",
                "10.0 Hz",
                "20.0 Hz",
                "50.0 Hz",
                "100.0 Hz"
              ]
            },
            "cdAutozero": {
              "type": "boolean",
              "title": "CD autozero",
              "description": "",
              "default": true
            }
          },
          "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0003",
          "type": "object"
        },
        "suppressorSettings": {
          "title": "Suppressor settings",
          "description": "",
          "required": [
            "suppressorType",
            "carbonateSuppression",
            "bicarbonateSuppression",
            "hydroxideSuppression",
            "tetraborateSuppression",
            "otherSuppression",
            "suppressorCurrent"
          ],
          "properties": {
            "suppressorType": {
              "title": "Suppressor type",
              "description": "",
              "type": "string",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0011",
              "enum": [
                "ARDS 2mm",
                "AERS 2mm",
                "None"
              ]
            },
            "carbonateSuppression": {
              "title": "Carbonate suppression [mM]",
              "description": "Provide molarity for total suppresor current calculation.",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0050",
              "type": "number",
              "minimum": 0,
              "maximum": 25
            },
            "bicarbonateSuppression": {
              "title": "Bicarbonate suppression [mM]",
              "description": "Provide molarity for total suppresor current calculation.",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0045",
              "maximum": 25
            },
            "hydroxideSuppression": {
              "title": "Hydroxide suppression [mM]",
              "description": "Provide molarity for total suppresor current calculation.",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0061",
              "minimum": 0,
              "maximum": 200
            },
            "tetraborateSuppression": {
              "title": "Tetraborate suppression [mM]",
              "description": "Provide molarity for total suppresor current calculation.",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0071",
              "minimum": 0,
              "maximum": 75
            },
            "otherSuppression": {
              "title": "Other suppression [mM]",
              "description": "Provide total molarity for total suppresor current calculation.",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0066",
              "minimum": 0,
              "maximum": 100
            },
            "suppressorCurrent": {
              "title": "Suppressor current [mA]",
              "description": "Sometimes automatically calculated from the software by providing molarities of the eluent.\nCurrent (mA) = Flow rate (mL/min) × [Eluent concentration (mN)] × Suppressor specific factor",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0078",
              "type": "number",
              "minimum": 0,
              "maximum": 150
            }
          },
          "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0010",
          "type": "object"
        }
      },
      "type": "object",
      "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0001"
    },
    "processingMethod": {
      "title": "Processing method",
      "description": "",
      "properties": {
        "ProcessingStandardDetectionWindows": {
          "title": "Standard detection windows",
          "description": "",
          "properties": {
            "voidRetentiontime": {
              "title": "Void retention time [min]",
              "description": "",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0072",
              "type": "number",
              "minimum": 0
            },
            "voidWindow": {
              "title": "Void window [min]",
              "description": "Defines the allowed difference to the defined retention time.",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0073",
              "minimum": 0
            },
            "fluorideRetentiontime": {
              "title": "Fluoride retention time [min]",
              "description": "",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0059",
              "type": "number",
              "minimum": 0,
              "maximum": 100000
            },
            "fluorideWindow": {
              "title": "Fluoride window [min]",
              "description": "Defines the allowed difference to the defined retention time.",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0060"
            },
            "chlorideRetentiontime": {
              "title": "Chloride retention time [min]",
              "description": "",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0053",
              "type": "number",
              "minimum": 0
            },
            "chlorideWindow": {
              "title": "Chloride window [min]",
              "description": "Defines the allowed difference to the defined retention time.",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0054",
              "minimum": 0
            },
            "nitriteRetentiontime": {
              "title": "Nitrite retention time [min]",
              "description": "",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0064",
              "minimum": 0
            },
            "nitriteWindow": {
              "title": "Nitrite window [min]",
              "description": "Defines the allowed difference to the defined retention time.",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0065",
              "minimum": 0
            },
            "carbonateRetentiontime": {
              "title": "Carbonate retention time [min]",
              "description": "",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0049",
              "minimum": 0
            },
            "carbonateWindow": {
              "title": "Carbonate window [min]",
              "description": "Defines the allowed difference to the defined retention time.",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0051",
              "minimum": 0
            },
            "bromideRetentiontime": {
              "title": "Bromide retention time [min]",
              "description": "",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0046",
              "minimum": 0
            },
            "bromideWindow": {
              "title": "Bromide window [min]",
              "description": "Defines the allowed difference to the defined retention time.",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0047",
              "minimum": 0
            },
            "sulfateRetentiontime": {
              "title": "Sulfate retention time [min]",
              "description": "",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0069",
              "minimum": 0
            },
            "sulfateWindow": {
              "title": "Sulfate window [min]",
              "description": "Defines the allowed difference to the defined retention time.",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0070",
              "type": "number"
            },
            "nitrateRetentiontime": {
              "title": "Nitrate retention time [min]",
              "description": "",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0062",
              "type": "number",
              "minimum": 0
            },
            "nitrateWindow": {
              "title": "Nitrate window [min]",
              "description": "Defines the allowed difference to the defined retention time.",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0063",
              "type": "number",
              "minimum": 0
            },
            "phosphateRetentiontime": {
              "title": "Phosphate retention time [min]",
              "description": "",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0067"
            },
            "phosphateWindow": {
              "title": "Phosphate window [min]",
              "description": "Defines the allowed difference to the defined retention time.",
              "type": "number",
              "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0068"
            }
          },
          "type": "object"
        }
      },
      "type": "object",
      "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0013"
    },
    "columnProperties": {
      "title": "Column properties",
      "description": "",
      "required": [
        "columnLot",
        "separationColumnLength",
        "columnTemperature",
        "separationColumnDiameter",
        "separationColumnName"
      ],
      "properties": {
        "guardColumn": {
          "title": "Guard column",
          "description": "",
          "$id": "https://plasma-mds.org/ontology/IC_Ontology/IC_C0015",
          "type": "boolean"
        },
        "guardColumnName": {
